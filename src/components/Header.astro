---
// src/components/Header.astro
const navItems = [
  { href: '/blog/about_me', label: 'About Me' },
  { href: '/', label: 'Blog' },
];

---

<header>
  <div class="head_contents">
    <div class="left_head">
      <div class="head-icon">
        <a href="/">
          <p id="title_p">@Uliboooo</p>
        </a>
      </div>
    </div>
    <div class="right_content">
      <ul>
        {
        navItems.map(item => (
          <li class="head-item"><a href={item.href}>{item.label}</a></li>
        ))
        }
      </ul>
      <ul id="sns_links">
      <button id="theme-toggle" aria-label="テーマ切り替え" class="theme-btn">
        🌙
      </button>
      </ul>
    </div>
  </div>
</header>

<style>
  header {
    border-bottom: 1px solid #ddd;
    padding-top: 5px;
    padding-bottom: 5px;
    font-size: 1.1rem;
  }
  .head_contents {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;

    .head-item a{
      font-size: 1rem;
    }

    .left_head {
      #title_p {
        font-size: 1.4rem;
        margin: 0;
        font-family: var(--base-fonts);
        color: var(--header-title-color);
        font-weight: bold;
      }
      a,
      a:visited {
        text-decoration: none;
        color: var(--header-title-color);
      }
      ul {
        list-style: none;
        display: flex;
        align-items: center;
        gap: 15px;
        padding-left: 0;
      }
      display: flex;
      align-items: center;
      gap: 15px;
    }

    .right_content {
      display: flex;
      flex-wrap: wrap;
      justify-self: center;
      align-items: center;
      gap: 0.6rem;
    }

    .right_content ul {
      display: flex;
      flex-wrap: wrap;
      list-style: none;
      gap: 0.6rem;
      align-items: center;
      padding-left: 10px;

      #sns_links {
        font-size: 1rem;
      }

      li a,
      li a:visited {
        text-decoration: none;
        color: var(--text);
      }
    }
  }

  .theme-btn {
    background: none;
    border: none;
    cursor: pointer;
    font-size: 1.1rem;
    padding: 0.25rem;
  }

  @media (max-width: 640px) {
    font-size: 90%;
    header {
      font-size: 90%;
    }
    .head_contents {
      justify-content: center;
      gap: 10px;
      ul {
        margin-top: 0px;
        margin-bottom: 0px;
      }
    }
  }
</style>

<script>
  const button = document.getElementById('theme-toggle');

  const updateButton = () => {
    const isDark = document.documentElement.classList.contains('dark');
    if (button) button.textContent = isDark ? '🔆' : '🌙';
  };

  button?.addEventListener('click', () => {
    const isDark = document.documentElement.classList.contains('dark');
    if (isDark) {
      document.documentElement.classList.remove('dark');
      localStorage.setItem('theme', 'light');
    } else {
      document.documentElement.classList.add('dark');
      localStorage.setItem('theme', 'dark');
    }
    updateButton();
  });

  updateButton();
</script>
