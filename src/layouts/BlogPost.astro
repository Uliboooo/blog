---
// src/layouts/BlogPost.astro
const { title, date } = Astro.props;
---

<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <title>{title}</title>
  </head>
  <body>
    <article>
      <h1>{title}</h1>
      <time>{date.toLocaleDateString('ja-JP')}</time>
      <slot />
    </article>
  </body>
</html>
