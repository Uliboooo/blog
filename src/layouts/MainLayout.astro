---
// src/layouts/MainLayout.astro
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const { title, description, ogImage, ogType = 'website' } = Astro.props as {
  title: string;
  description?: string;
  ogImage?: string;
  ogType?: string;
};
const trimmedDescription = description?.trim();
const canonical = new URL(Astro.url.pathname, Astro.site).href;
const resolvedOgImage = ogImage ? new URL(ogImage, Astro.site).href : undefined;
const siteName = "Uliboooo's blog";
---

<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    {trimmedDescription && (
      <meta name="description" content={trimmedDescription} />
    )}
    <link rel="canonical" href={canonical} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={title} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonical} />
    {trimmedDescription && (
      <meta property="og:description" content={trimmedDescription} />
    )}
    {resolvedOgImage && (
      <>
        <meta property="og:image" content={resolvedOgImage} />
        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:image" content={resolvedOgImage} />
      </>
    )}
    <meta name="twitter:title" content={title} />
    {trimmedDescription && (
      <meta name="twitter:description" content={trimmedDescription} />
    )}
    <script is:inline>
      const theme = (() => {
        if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
          return localStorage.getItem('theme');
        }
        if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
          return 'dark';
        }
        return 'light';
      })();

      if (theme === 'light') {
        document.documentElement.classList.remove('dark');
      } else {
        document.documentElement.classList.add('dark');
      }
      window.localStorage.setItem('theme', theme);
    </script>
  </head>
  <body>
    <Header />
      <main>
        <slot />
      </main>
    <Footer />
  </body>
</html>
